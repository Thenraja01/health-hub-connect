# Database Configuration
DATABASE_URL="mongodb+srv://user:pass@cluster.mongodb.net/dbname"

# Server Configuration
PORT=5002
NODE_ENV=development

# Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_...
