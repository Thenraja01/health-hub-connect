# ============================================================================
# HEALTH HUB BACKEND - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# SECURITY: Never commit .env file with real secrets to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/health_hub"

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:5000

# ============================================================================
# JWT AUTHENTICATION (REQUIRED - DO NOT USE DEFAULTS IN PRODUCTION)
# ============================================================================
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key
JWT_EXPIRES_IN=7d

# ============================================================================
# PAYMENT GATEWAYS
# ============================================================================
# Stripe (Recommended for online payments with Connect for doctor payouts)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay (Alternative Indian payment gateway)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============================================================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================================================
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:5173
FRONTEND_DOMAIN=localhost

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# AWS S3 (For file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=health-hub-uploads
AWS_REGION=us-east-1

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ============================================================================
# SECURITY
# ============================================================================
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# REDIS (Optional - for caching and sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================================
# VIDEO CONSULTATION (For WebRTC)
# ============================================================================
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_VIDEO_CONSULTATION=true
ENABLE_AI_DIAGNOSIS=false
ENABLE_PRESCRIPTION_AUTOMATION=true

